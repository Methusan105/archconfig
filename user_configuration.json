{
    "app_config": {
        "audio_config": {
            "audio": "pulseaudio"
        },
        "bluetooth_config": {
            "enabled": true
        }
    },
    "archinstall_language": "English",
    "auth_config": {},
    "bootloader_config": {
        "bootloader": "Grub",
        "removable": true,
        "uki": false
    },
    "custom_commands": [],
    "hostname": "archlinux",
    "kernels": [
        "linux"
    ],
    "locale_config": {
        "console_font": "default8x16",
        "kb_layout": "no",
        "sys_enc": "UTF-8",
        "sys_lang": "nb_NO.UTF-8"
    },
    "mirror_config": {
        "custom_repositories": [],
        "custom_servers": [],
        "mirror_regions": {
            "Norway": [
                "http://mirror.archlinux.no/$repo/os/$arch",
                "https://mirror.archlinux.no/$repo/os/$arch",
                "http://archlinux.uib.no/$repo/os/$arch",
                "http://mirror.neuf.no/archlinux/$repo/os/$arch",
                "https://mirror.neuf.no/archlinux/$repo/os/$arch",
                "https://archlinux.lysakermoen.com/$repo/os/$arch",
                "http://no.mirror.cx/archlinux/$repo/os/$arch",
                "https://no.mirror.cx/archlinux/$repo/os/$arch"
            ]
        },
        "optional_repositories": []
    },
    "network_config": {
        "type": "nm"
    },
    "ntp": true,
    "packages": [
        "konsole",
        "dolphin"
    ],
    "pacman_config": {
        "color": true,
        "parallel_downloads": 5
    },
    "profile_config": {
        "gfx_driver": "Intel (open-source)",
        "greeter": "plasma-login-manager",
        "profile": {
            "custom_settings": {
                "KDE Plasma": {
                    "plasma_flavor": "plasma-meta"
                }
            },
            "details": [
                "KDE Plasma"
            ],
            "main": "Desktop"
        }
    },
    "script": null,
    "services": [],
    "swap": {
        "algorithm": "zstd",
        "enabled": true
    },
    "timezone": "Europe/Oslo",
    "version": "4.4"
}
