{
  "app_config": {
    "bluetooth_config": {
      "enabled": true
    }
  },

  "archinstall_language": "English",

  "bootloader_config": {
    "bootloader": "Grub",
    "removable": true,
    "uki": false
  },

  "hostname": "archlinux",

  "kernels": [
    "linux-zen",
    "linux"
  ],

  "locale_config": {
    "console_font": "default8x16",
    "kb_layout": "no",
    "sys_enc": "UTF-8",
    "sys_lang": "nb_NO.UTF-8"
  },

  "mirror_config": {
    "mirror_regions": {
      "Norway": [
        "https://mirror.archlinux.no/$repo/os/$arch",
        "https://mirror.neuf.no/archlinux/$repo/os/$arch"
      ]
    }
  },

  "network_config": {
    "type": "nm"
  },

  "ntp": true,

  "packages": [
    "konsole",
    "dolphin",
    "ark",
    "kate",
    "gwenview",
    "spectacle",
    "filelight",

    "zip",
    "unzip",
    "vlc",
    "vlc-plugins-all",
    "mission-center",
    "transmission-gtk",
    "aria2",
    "spotify-launcher",

    "intel-ucode",

    "pipewire",
    "pipewire-pulse",
    "wireplumber",
    "bluedevil",
    "plasma-pa",

    "mesa",
    "intel-media-driver",

    "thermald",
    "power-profiles-daemon",
    "systemd-zram-generator",

    "reflector",

    "fastfetch",
    "btop",
    "eza",
    "bat",
    "fd",
    "ripgrep",
    "fzf",
    "zoxide"
  ],

  "pacman_config": {
    "color": true,
    "parallel_downloads": 10
  },

  "profile_config": {
    "gfx_driver": "Intel (open-source)",
    "greeter": "plasma-login-manager",
    "profile": {
      "details": [
        "KDE Plasma"
      ],
      "main": "Desktop"
    }
  },

  "services": [
    "bluetooth",
    "fstrim.timer",
    "thermald",
    "power-profiles-daemon",
    "systemd-resolved"
  ],

  "swap": {
    "algorithm": "zstd",
    "enabled": true
  },

  "timezone": "Europe/Oslo",

  "version": "4.4"
}
